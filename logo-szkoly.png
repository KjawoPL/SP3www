<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 220" width="200" height="220">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0d1f3c"/>
      <stop offset="100%" style="stop-color:#1a3157"/>
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#e8b84b"/>
      <stop offset="100%" style="stop-color:#c8962a"/>
    </linearGradient>
  </defs>
  <!-- Shield shape -->
  <path d="M100 8 L190 40 L190 130 Q190 185 100 212 Q10 185 10 130 L10 40 Z"
        fill="url(#bg)" stroke="#c8962a" stroke-width="3"/>
  <!-- Gold band bottom of shield -->
  <path d="M10 155 Q10 185 100 212 Q190 185 190 155 Z" fill="url(#gold)" opacity="0.9"/>
  <!-- Number 3 -->
  <text x="100" y="110" font-family="Georgia,serif" font-size="80" font-weight="900"
        fill="white" text-anchor="middle" dominant-baseline="middle">3</text>
  <!-- Top gold line accent -->
  <line x1="40" y1="145" x2="160" y2="145" stroke="#e8b84b" stroke-width="2" opacity="0.6"/>
  <!-- Stars -->
  <text x="55" y="195" font-size="18" fill="white" text-anchor="middle">&#9733;</text>
  <text x="100" y="203" font-size="18" fill="white" text-anchor="middle">&#9733;</text>
  <text x="145" y="195" font-size="18" fill="white" text-anchor="middle">&#9733;</text>
</svg>